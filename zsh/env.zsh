export GEM_PATH=~/.gem/ruby/2.7.0/bin
export GOPLS_PATH=~/.go/bin
export YARN_PATH=~/.yarn/bin
export LOCAL_PATH=~/.local/bin
export DOOM_PATH=~/.emacs.d/bin

export ZSH=/usr/share/oh-my-zsh
export PATH=$PATH:$GEM_PATH:$GOPLS_PATH:$YARN_PATH:$LOCAL_PATH:$DOOM_PATH

export GOPATH=~/.go
export FLUTTER_STORAGE_BASE_URL="https://mirrors.bfsu.edu.cn/flutter"
export PUB_HOSTED_URL="https://mirrors.bfsu.edu.cn/dart-pub"
export ANDROID_HOME=/opt/android-sdk
export XDG_CONFIG_HOME=$HOME/.config
export EDITOR='nvim'
export ZSH_AUTOSUGGEST_USE_ASYNC=1
export ZSH_AUTOSUGGEST_MANUAL_REBIND=1
export RANGER_LOAD_DEFAULT_RC="false"
export TERM=xterm-256color
export TERM_ITALICS=true
export PATH="$PATH:/home/keith/.dotnet/tools"
export GLFW_IM_MODULE=ibus
